{
  "name": "visual-pitch-trainer",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "install:locked": "bun install --frozen-lockfile",
    "audit:dependencies": "bun audit --audit-level=high",
    "dev": "bun run scripts/dev.ts",
    "download:pitch-models": "bun run scripts/download-pitch-models.ts",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview --host 0.0.0.0",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "lint": "biome check .",
    "test": "bun test src",
    "test:coverage": "bun test src --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "demucs-web": "^1.0.2",
    "mediabunny": "^1.40.1",
    "onnxruntime-web": "^1.24.3",
    "pitchy": "4.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2",
    "vite": "8.0.10"
  }
}
