{
  "name": "visual-pitch-trainer",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "install:locked": "bun install --frozen-lockfile",
    "audit:dependencies": "bun audit --audit-level=high",
    "dev": "bunx --bun vite --host 0.0.0.0",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pitchfinder": "^2.3.4"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "8.0.10"
  }
}
